# HermesAgency deployment manifest — generated by `agency init`.
# Edit this file directly to evolve your deployment; framework upgrades
# never overwrite it.
#
# This file is the deployment's source of truth for: who owns this
# agency, which roles are active, where they live on disk, and how they
# talk to your inference provider(s). Every other config in the
# deployment derives from this manifest.
#
# Schema validation lives in `_framework/manifest.py`. Run
# `agency status` to validate after edits.

deployment:
  owner:             "{{OWNER_HANDLE}}"            # short handle (e.g. "j-doe")
  org_name:          "{{ORG_NAME}}"                # display name (e.g. "Jane Doe Consulting")
  primary_email:     "{{PRIMARY_EMAIL}}"           # owner's working address
  timezone:          "{{TIMEZONE}}"                # IANA tz (e.g. "America/Chicago")
  framework_version: "0.1.0"                       # framework-version.lock pins this

# ── Active profiles ──────────────────────────────────────────────────────
# Required roles: chief-of-staff, knowledge-base, system-sentinel.
# Optional roles: analyst-judge, business-development, writing-support.
# Custom roles: add `_framework/roles/<id>/` or `~/.agency/custom-roles/<id>/`,
# then list here. Adding new agents post-init is supported via `agency add-role`.
profiles:

  - id:            "{{COS_ID}}"                    # operator's name for CoS (e.g. "loriah")
    role:          chief-of-staff
    persona_file:  "identities/chief-of-staff.md"  # SOUL.md content lives here
    email:         "{{COS_EMAIL}}"                 # the agency's ONE outbound mailbox
    starter_skills:                                # framework-provided starters
      - owner-channels-ingress
      - draft-composer
      - send-orchestrator
      - kanban-orchestrator
      - calendar-manager
      - morning-briefing
      - weekly-review
      - delegate-via-kanban
      - pipeline-watchdog

  - id:            "{{KB_ID}}"                     # operator's name for KB
    role:          knowledge-base
    persona_file:  "identities/knowledge-base.md"
    email:         null                            # default: single-mailbox via CoS
    starter_skills:
      - ip-curator
      - ip-alignment-check
      - methodology-application-check
      - prior-decision-search
      - meeting-evaluator
      - quality-auditor
      - kanban-verdict-publisher

  - id:            "{{SENTINEL_ID}}"               # default: "sentinel"; deployments can rename
    role:          system-sentinel
    persona_file:  "identities/system-sentinel.md"
    email:         null                            # never sends
    starter_skills:                                # framework-required for Sentinel
      - learning-monitor
      - drift-monitor
      - heartbeat-watch
      - playbook-audit
      - event-rollup
      - compliance-report

  # ── Optional roles ────────────────────────────────────────────────────
  # Comment out any role you don't want to deploy yet; you can add it
  # later with `agency add-role <role>`.

  - id:            "{{ANALYST_ID}}"                # e.g. "lynda"
    role:          analyst-judge
    persona_file:  "identities/analyst-judge.md"
    email:         null
    starter_skills:
      - red-team
      - dossier-builder
      - research
      - prompt-injection-defense
      - learning-curation
      - verifier-criteria-author
      - graduation-check

  - id:            "{{BD_ID}}"                     # e.g. "devon"
    role:          business-development
    persona_file:  "identities/business-development.md"
    email:         null                            # CoS drafts external mail
    starter_skills:
      - prospect-research
      - opportunistic-outreach
      - journalist-relationship
      - podcast-host-relationship
      - crm-sync
      - weekly-opportunity-scan

  - id:            "{{WRITING_ID}}"                # e.g. "libra"
    role:          writing-support
    persona_file:  "identities/writing-support.md"
    email:         null                            # author correspondence flows through CoS
    starter_skills:
      - book-coaching
      - manuscript-review
      - workbook-drafting
      - newsletter-drafting
      - multi-author-state

  # ── Example: adding a custom role ─────────────────────────────────────
  # Uncomment and customize when expanding. The role must exist in
  # _framework/roles/<id>/ or ~/.agency/custom-roles/<id>/. No code
  # change required — discovery is on-disk.
  #
  # - id:            finance
  #   role:          finance                # custom role
  #   persona_file:  identities/finance.md
  #   email:         null
  #   starter_skills:
  #     - cash-flow-tracker
  #     - burn-rate-monitor
  #     - vendor-research

# ── Inference defaults ───────────────────────────────────────────────────
# The framework is vendor-neutral. Any OpenAI-compatible endpoint
# works. The deployment picks. Per-profile overrides take precedence:
#   profile.config.yaml > deployment defaults > framework default
defaults:
  model:    "{{DEFAULT_MODEL}}"        # whatever your provider expects
  provider: "{{DEFAULT_PROVIDER}}"     # must be in invariants.yaml::valid_providers
  base_url: "{{DEFAULT_BASE_URL}}"     # http://localhost:11434/v1 for local Ollama,
                                       # or https://your-provider.example/v1

  # Optional cascade if primary fails (each fallback has the same shape):
  fallback_providers: []
  #   - provider: openai
  #     model:    gpt-4o
  #     base_url: https://api.openai.com/v1

# ── Credentials ──────────────────────────────────────────────────────────
# NEVER inline values. Use Keychain refs (`keychain:<entry-name>`) or
# environment refs (`env:OPENAI_API_KEY`). One entry per provider in use.
credentials:
  "{{DEFAULT_PROVIDER}}": "keychain:{{DEFAULT_CREDENTIAL_NAME}}"

# ── Send-guard access list ───────────────────────────────────────────────
# Whitelist / greylist / blacklist of recipients, owned by the CoS profile.
# `email-access.md` is the human-edited source; send_guard.py reads it.
email_access_file: "profiles/{{COS_ID}}/scripts/learning-system/email-access.md"

# ── Ingress channels (T2 wizard sets these) ──────────────────────────────
# How the owner talks to CoS. Email is the default; the rest are
# optional but normalize into the same CoS triage surface.
ingress:
  email:     true
  chat_tab:  true          # dashboard chat at https://localhost:9118/chat
  signal:    false
  slack:     false
